{
  "expo": {
    "name": "NutriVoice",
    "slug": "nutrivoice",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "nutrivoice",
    "userInterfaceStyle": "dark",
    "backgroundColor": "#0B0D10",
    "ios": {
      "icon": "./assets/expo.icon",
      "bundleIdentifier": "com.arjun.nutrivoice",
      "infoPlist": {
        "NSCameraUsageDescription": "NutriVoice uses the camera to scan food barcodes."
      }
    },
    "android": {
      "package": "com.arjun.nutrivoice",
      "adaptiveIcon": {
        "backgroundColor": "#0B0D10",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#0B0D10",
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 76
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "NutriVoice uses the camera to scan food barcodes."
        }
      ],
      [
        "expo-speech-recognition",
        {
          "microphonePermission": "NutriVoice uses the microphone so you can log food by talking.",
          "speechRecognitionPermission": "NutriVoice uses speech recognition to turn what you say into a food log."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
